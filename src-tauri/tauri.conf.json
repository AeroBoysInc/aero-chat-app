{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AeroChat",
  "version": "0.1.0",
  "identifier": "com.aeroboysinc.aero-chat",
  "build": {
    "beforeDevCommand": "$HOME/.local/bin/pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "$HOME/.local/bin/pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AeroChat",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
