VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── TURN server (Cloudflare Calls) ──────────────────────────────────────
# These are Supabase Edge Function secrets (NOT client-side env vars).
# Set via: supabase secrets set CLOUDFLARE_TURN_KEY_ID=xxx CLOUDFLARE_TURN_API_TOKEN=xxx
# Get credentials from: Cloudflare Dashboard → Calls → TURN Keys
